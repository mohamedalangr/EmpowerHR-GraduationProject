# Core production settings
SECRET_KEY=change-me-in-production
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
CORS_ALLOWED_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
DATABASE_URL=

# Cookie / HTTPS defaults
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_SSL_REDIRECT=False
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False
SESSION_COOKIE_SAMESITE=Lax
CSRF_COOKIE_SAMESITE=Lax

# Optional legacy aliases (still supported)
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_CSRF_TRUSTED_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
DJANGO_CORS_ALLOWED_ORIGINS=http://127.0.0.1:3000,http://localhost:3000

# Production example values for Railway + Vercel
# DEBUG=False
# ALLOWED_HOSTS=your-backend-name.up.railway.app
# CSRF_TRUSTED_ORIGINS=https://your-frontend-name.vercel.app,https://your-backend-name.up.railway.app
# CORS_ALLOWED_ORIGINS=https://your-frontend-name.vercel.app
# DATABASE_URL=postgresql://...
# SECRET_KEY=use-a-long-random-secret

# Optional Cloudinary media storage for CVs / uploaded files
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Optional alternative:
# CLOUDINARY_URL=cloudinary://<api_key>:<api_secret>@<cloud_name>

SKILLS_TAXONOMY_CSV=it-job-roles-skills-analysis.csv
SENTENCE_TRANSFORMER_MODEL=anass1209/resume-job-matcher-all-MiniLM-L6-v2
